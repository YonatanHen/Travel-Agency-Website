{
  "name": "user-service",
  "version": "1.0.0",
  "description": "User management microservice for Travel-Agency-Website",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "NODE_ENV=development nodemon src/server.js",
    "test": "NODE_ENV=test jest --coverage",
    "test:watch": "NODE_ENV=test jest --watch",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\""
  },
  "dependencies": {
    "@travel-agency/shared-config": "^1.0.0",
    "@travel-agency/shared-errors": "^1.0.0",
    "@travel-agency/shared-utils": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^6.1.2",
    "joi": "^17.9.2",
    "mongoose": "^7.0.3"
  },
  "devDependencies": {
    "@shelf/jest-mongodb": "^2.2.3",
    "eslint": "^8.24.0",
    "jest": "^29.3.1",
    "nodemon": "^2.0.20",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}