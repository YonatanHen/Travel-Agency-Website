{
  "name": "travel-agency-microservices",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "services/*",
    "gateway",
    "shared/*"
  ],
  "scripts": {
    "dev": "docker-compose up",
    "setup": "node scripts/generate-env.js",
    "build": "lerna run build --parallel",
